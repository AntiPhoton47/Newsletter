# SMTP settings
NEWSLETTER_SMTP_HOST=smtp.gmail.com
NEWSLETTER_SMTP_PORT=587
NEWSLETTER_SMTP_SECURITY=starttls
NEWSLETTER_SMTP_USERNAME=your-email@example.com
NEWSLETTER_SMTP_PASSWORD=your-app-password

# Delivery
NEWSLETTER_FROM=Frontier Threads <your-email@example.com>
NEWSLETTER_TO=your-email@example.com
NEWSLETTER_SUBJECT_PREFIX=Frontier Threads

# Archive publishing
NEWSLETTER_ARCHIVE_BASE_URL=https://<your-github-pages-domain>/

# AI editorial layer
OPENAI_API_KEY=
NEWSLETTER_USE_AI=true
NEWSLETTER_REQUIRE_AI=false
NEWSLETTER_OPENAI_BASE_URL=https://api.openai.com/v1
NEWSLETTER_OPENAI_DRAFT_MODEL=gpt-4.1-mini
NEWSLETTER_OPENAI_REVIEW_MODEL=gpt-4.1-mini
NEWSLETTER_AI_REVIEW_MIN_SCORE=85
